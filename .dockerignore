# Exclude heavy / regenerated content from the docker build context.
# Without this file the build context becomes ~2GB (mostly node_modules + .git)
# and the Emergent build pipeline times out uploading to Cloudflare R2.

# Node deps — re-installed inside the build container.
**/node_modules
**/.yarn
**/.pnp
**/.pnp.js
.yarn/install-state.gz

# Build outputs — regenerated by the build container.
**/build
**/dist
**/.next
**/out

# Test / coverage / cache / dev artifacts.
**/.pytest_cache
**/__pycache__
**/.ruff_cache
**/.mypy_cache
**/coverage
**/.cache
**/.parcel-cache

# Git, IDE, OS junk.
.git
.gitignore
.gitconfig
.idea
.vscode
.DS_Store
*.swp
*.swo

# Logs and temp files.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
**/.npm

# Emergent-specific dev artifacts that shouldn't ship.
test_reports
auth_testing.md
plan.md
test_result.md
admin_backend_test.py
backend_test.py
tests/
yarn.lock

# Local env overrides (real .env files are still included; only local overrides excluded).
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Stale Next.js scratch dir (we keep it preserved outside of /app at /root/frontend-next-bak).
frontend-next
frontend-next-bak

# Memory and design docs are not needed at runtime.
memory
design_guidelines.json
design_guidelines.md
